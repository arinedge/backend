# Application
APP_NAME=PortalBackend
APP_VERSION=1.0.0
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-very-long-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh Token
REFRESH_TOKEN_EXPIRE_DAYS=30

# Auth Cookies
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15

# Email Verification Token
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:4200

# Zavudev (Zavu) Email
ZAVUDEV_API_KEY=your_zavudev_api_key_here
ZAVU_SENDER_EMAIL=no-reply@arinedge.com

UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_CACHE_TTL=300
